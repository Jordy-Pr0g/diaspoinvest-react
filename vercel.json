{
  "crons": [
    { "path": "/api/stats?cron=digest", "schedule": "0 8 * * *" }
  ],
  "redirects": [
    { "source": "/dividendes", "destination": "/screener", "permanent": true },
    { "source": "/tiktok", "destination": "/?src=tiktok", "permanent": false },
    { "source": "/facebook", "destination": "/?src=facebook", "permanent": false },
    { "source": "/fb", "destination": "/?src=facebook", "permanent": false },
    { "source": "/linkedin", "destination": "/?src=linkedin", "permanent": false },
    { "source": "/insta", "destination": "/?src=instagram", "permanent": false },
    { "source": "/whatsapp", "destination": "/?src=whatsapp", "permanent": false },
    { "source": "/youtube", "destination": "/?src=youtube", "permanent": false }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/google(.*).html", "destination": "/google$1.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",      "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",           "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
